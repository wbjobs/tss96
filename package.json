{
  "name": "clip-sync",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-device clipboard sync tool",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "server": "node server/index.js",
    "client": "node client/node_modules/.bin/electron .",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
